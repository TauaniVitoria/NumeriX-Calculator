{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CalculadoraMetodos",
  "version": "1.0.0",
  "identifier": "com.tauani.calculadora",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CalculadoraMetodos",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pt-BR"
      },
      "nsis": {
        "languages": [
          "PortugueseBrazilian"
        ]
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
